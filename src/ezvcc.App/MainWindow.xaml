<Window x:Class="Ezvcc.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ezvcc"
        Height="260" Width="420"
        MinHeight="220" MinWidth="360">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding StatusText}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <TextBlock Grid.Row="1"
                   Text="入力レベル"
                   FontSize="12"
                   Foreground="#555"
                   Margin="0,0,0,4" />

        <ProgressBar Grid.Row="2"
                     Height="20"
                     Minimum="0"
                     Maximum="1"
                     Value="{Binding InputLevel}" />

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="開始"
                    Command="{Binding StartCommand}"
                    MinWidth="96"
                    Height="32"
                    Margin="0,0,8,0" />
            <Button Content="停止"
                    Command="{Binding StopCommand}"
                    MinWidth="96"
                    Height="32" />
        </StackPanel>
    </Grid>
</Window>
